        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"query\": \"Latest news, insights, and analysis about {{$json.topic}}. Focus on high-quality sources.\",\n  \"search_depth\": \"basic\",\n  \"chunks_per_source\": 3,\n  \"max_results\": 3,\n  \"topic\": \"news\",\n  \"time_range\": \"month\",\n  \"include_answer\": false,\n  \"include_raw_content\": true,\n  \"include_images\": false,\n  \"include_image_descriptions\": false,\n  \"include_favicon\": false,\n  \"include_domains\": [],\n  \"exclude_domains\": [],\n  \"auto_parameters\": false,\n  \"exact_match\": false,\n  \"include_usage\": false\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
