      ],
      "id": "5e4adc02-6db7-48b8-ba57-0011cb984fde",
      "name": "HTTP Request"
    },
    {
      "parameters": {
        "jsCode": "const raw = ($json.message?.text || '').trim();\nconst lowered = raw.toLowerCase();\n\nif (lowered === 'approve' || lowered === 'redo' || lowered === 'skip') {\n  return [\n    {\n      json: {\n        valid: true,\n        kind: 'decision',\n        action: lowered,\n        raw,\n        chatId: $json.message?.chat?.id\n      }\n    }\n  ];\n}\n\nconst match = raw.match(/^(viral|authority|dm)\\s*:\\s*(.+)$/i);\n\nif (!match) {\n  return [\n    {\n      json: {\n        valid: false,\n        kind: 'invalid',\n        error: 'Message must be approve, redo, skip, or start with viral:, authority:, or dm:',\n        raw,\n        chatId: $json.message?.chat?.id\n      }\n    }\n  ];\n}\n\nconst mode = match[1].toLowerCase();\nconst topic = match[2].trim();\n\nreturn [\n  {\n    json: {\n      valid: true,\n      kind: 'new_post',\n      mode,\n      topic,\n      raw,\n      chatId: $json.message?.chat?.id\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1280,
        -48
      ],
      "id": "756d12fa-71e3-4aec-a666-ea6749ecf5bc",
      "name": "Trigger Code"
    },
    {
      "parameters": {
        "jsCode": "const mode = $('Post Context').first().json.mode ?? '';\nconst topic = $('Post Context').first().json.topic ?? '';\n\nconst results = $json.results || [];\n\nconst sourcesText = results\n  .slice(0, 3)\n  .map((r, i) => {\n    const title = r.title || `Source ${i + 1}`;\n    const url = r.url || '';\n    const content = (r.raw_content || r.content || '').slice(0, 1200);\n\n    return `Source ${i + 1}\nTitle: ${title}\nURL: ${url}\n\n${content}`;\n  })\n  .join('\\n\\n---\\n\\n');\n\nreturn [{\n  json: {\n    mode,\n    topic,\n    sourcesText\n  }\n}];"
      },
